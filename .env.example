# =============================================================================
# Copier vers .env et remplir. Ne jamais committer .env (reste local / CI secret).
# =============================================================================

# --- Supabase (front Vite : obligatoire si tu n’utilises plus l’API Express) ---
# Dashboard → Project Settings → API
#
# ⚠️ NE PAS copier tel quel les lignes ci-dessous : remplacez par VOS valeurs du dashboard.
# Si l’URL contient encore « votre_ref » ou un faux hôte → erreur net::ERR_NAME_NOT_RESOLVED dans le navigateur.
#
# L’URL réelle ressemble à : https://abcdefghijklmnop.supabase.co (sous-domaine = ref du projet)
# La clé « anon » est une très longue chaîne JWT (souvent 200+ caractères), commençant par eyJ...
# Ne jamais mettre la clé service_role ici (elle est secrète ; le front l’exposerait).
#
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Si renseigné (URL absolue https://…), les liens « Connexion » et les redirections
# (admin non connecté, déconnexion) envoient vers cette page au lieu de /login sur ce site.
# Ex. : https://www.exemple.com/login ou un fournisseur d’identité.
# VITE_EXTERNAL_LOGIN_URL=

# --- Import script SQLite → Supabase (optionnel, terminal uniquement) ---
# Même URL projet ; clé « service_role » (secret) — jamais en VITE_* ni dans le front.
SUPABASE_URL=https://VOTRE_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.EXEMPLE_SERVICE_ROLE_SECRETE

# Chemin vers la base locale à importer (défaut : ./data/orbis.db)
# SQLITE_PATH=./data/orbis.db

# --- Backend Express + SQLite (si VITE_SUPABASE_* vides : npm run dev avec API) ---
PORT=3001
# SQLITE_PATH=./data/orbis.db

ADMIN_EMAIL=admin@exemple.org
ADMIN_PASSWORD=mot_de_passe_dev_seulement

# En production : hash bcrypt (prioritaire sur ADMIN_PASSWORD)
# ADMIN_PASSWORD_HASH=$2b$10$...

JWT_SECRET=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJhZG1pbiIsInJvbGUiOiJhZG1pbiIsImlhdCI6MTcxMDAwMDAwMH0.xxxxx_signature_xxxx

# Optionnel
# COOKIE_SECURE=true
# CORS_ORIGIN=https://www.votredomaine.com

# =============================================================================
# Rappels
# =============================================================================
# - Après migrations : INSERT dans public.site_admins (UUID Auth) → supabase/seed_first_admin.sql
# - Storage : bucket public admin-media (migrations + 20260417143000_storage_bucket_limits.sql)
# - Import : npm run import:sqlite-to-supabase -- --dry-run puis sans --dry-run ; exécuter le SQL setval affiché
